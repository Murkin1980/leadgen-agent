# === Production Environment Configuration ===
# Copy to .env and fill in real values.
# NEVER commit this file with real secrets.

APP_ENV=production
DATABASE_URL=postgresql+psycopg://user:password@host:5432/leadgen
REDIS_URL=redis://host:6379/0

# Text Generation
TEXT_GENERATOR_PROVIDER=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Preview
PUBLIC_BASE_URL=https://your-domain.com

# Deployment
DEPLOYMENT_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=leadgen-agent
CLOUDFLARE_PAGES_BRANCH=master
CLOUDFLARE_PUBLIC_URL=https://leadgen-agent.pages.dev

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Outreach
OUTREACH_PROVIDER=whatsapp
OUTREACH_ENABLED=false
OUTREACH_MODE=disabled
OUTREACH_SANDBOX_ALLOWLIST=+77000000001,+77000000002
OUTREACH_MAX_PER_HOUR=20
OUTREACH_QUIET_HOURS_START=09:00
OUTREACH_QUIET_HOURS_END=20:00
OUTREACH_TIMEZONE=Asia/Almaty
OUTREACH_SEND_MAX_RETRIES=5
OUTREACH_SEND_RETRY_BASE_SECONDS=30
OUTREACH_SEND_JOB_TIMEOUT_SECONDS=60

# WhatsApp Cloud API
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_SERVICE_WINDOW_HOURS=24
WHATSAPP_ALLOW_MOCK_WEBHOOKS=false
